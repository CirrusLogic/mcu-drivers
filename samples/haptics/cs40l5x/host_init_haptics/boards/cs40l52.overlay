#include <zephyr/dt-bindings/i2c/i2c.h>

&i2c1 {
        status = "okay";
        clock-frequency = <I2C_BITRATE_STANDARD>;
	pinctrl-0 = <&i2c1_scl_pb6 &i2c1_sda_pb7>;

        haptic1: cs40l52@34 {
                compatible = "cirrus,cs40l5x_alt_os";
                reg = <0x34>;
                reset-gpios = <&gpioa 6 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
                status = "okay";
        };
};

&usart1 {
	status = "disabled";
};